<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet author="dev.team" id="20260327-create-enrollments-table">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="enrollments"/>
            </not>
        </preConditions>

        <createTable tableName="enrollments">
            <column name="id" type="BIGINT" defaultValueSequenceNext="seq_enrollments_id">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="enrolled_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
        </createTable>

        <addUniqueConstraint
                tableName="enrollments"
                columnNames="student_id, course_id"
                constraintName="uq_enrollment_student_course"/>

        <addForeignKeyConstraint
                baseTableName="enrollments"
                baseColumnNames="student_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_enrollments_student"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="enrollments"
                baseColumnNames="course_id"
                referencedTableName="courses"
                referencedColumnNames="id"
                constraintName="fk_enrollments_course"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>