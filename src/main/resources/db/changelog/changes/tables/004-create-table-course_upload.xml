<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet author="dev.team" id="20260311-create-course-upload-table">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="course_upload"/>
            </not>
        </preConditions>

        <createTable tableName="course_upload">
            <column name="id" type="BIGINT" defaultValueSequenceNext="seq_course_upload_id">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="file_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="uploaded_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="course_upload"
                baseColumnNames="course_id"
                referencedTableName="courses"
                referencedColumnNames="id"
                constraintName="fk_course_upload_course"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="course_upload"
                baseColumnNames="student_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_course_upload_student"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="course_upload"
                baseColumnNames="file_id"
                referencedTableName="files"
                referencedColumnNames="id"
                constraintName="fk_course_upload_file"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>