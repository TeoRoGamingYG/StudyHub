<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet author="dev.team" id="20260327-create-files-table">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="files"/>
            </not>
        </preConditions>

        <createTable tableName="files">
            <column name="id" type="BIGINT" defaultValueSequenceNext="seq_files_id">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="file_path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="BIGINT"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="uploaded_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="uploaded_by" type="BIGINT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="OK"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="files"
                baseColumnNames="uploaded_by"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_files_uploaded_by"
                onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>