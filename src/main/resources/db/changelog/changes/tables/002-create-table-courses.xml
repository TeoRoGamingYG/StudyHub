<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet author="dev.team" id="20260327-create-courses-table">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="courses"/>
            </not>
        </preConditions>

        <createTable tableName="courses">
            <column name="id" type="BIGINT" defaultValueSequenceNext="seq_courses_id">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="icon" type="VARCHAR(10)"/>
            <column name="color" type="VARCHAR(20)"/>
            <column name="credits" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="semester" type="INTEGER"/>
            <column name="max_students" type="INTEGER"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="professor_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="courses"
                baseColumnNames="professor_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_courses_professor"
                onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>