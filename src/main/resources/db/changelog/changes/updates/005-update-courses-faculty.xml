<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet author="dev.team" id="20260723-add-faculty-to-courses">

        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="courses" columnName="faculty"/>
            </not>
        </preConditions>

        <addColumn tableName="courses">
            <column name="faculty" type="VARCHAR(100)" defaultValue="Facultatea de Matematica si Informatica">
                <constraints nullable="false"/>
            </column>
        </addColumn>

    </changeSet>

</databaseChangeLog>