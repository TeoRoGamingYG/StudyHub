<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet author="dev.team" id="20260630-update-courses-remove-columns">

        <preConditions onFail="MARK_RAN">
            <tableExists tableName="courses"/>
        </preConditions>

        <dropColumn tableName="courses" columnName="description"/>
        <dropColumn tableName="courses" columnName="icon"/>
        <dropColumn tableName="courses" columnName="color"/>
        <dropColumn tableName="courses" columnName="max_students"/>

    </changeSet>

</databaseChangeLog>